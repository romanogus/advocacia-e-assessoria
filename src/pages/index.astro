---
import Layout from '../layouts/Layout.astro';

import { sanityClient } from 'sanity:client';

const whatsappPhone = "5511955304453";
const whatsappMessage = "Olá! Gostaria de mais informações sobre os serviços jurídicos.";
const whatsappUrl = `https://wa.me/${whatsappPhone}?text=${encodeURIComponent(whatsappMessage)}`;

const areas = await sanityClient.fetch(
  `*[_type == "areaDeAtuacao"] | order(order asc) {
    _id,
    title,
    description,
    icon,
    order
  }`
);

// Maps a keyword (lowercase, found anywhere in the title) to a public image path.
// To add a new area image, just add another entry here.
const areaBackgrounds: Record<string, string> = {
  trabalhist: '/direito-trab.webp',
  civil: '/direito-civil.webp',
  previdenci: '/direito-prev.webp',
  // consumidor: '/direito-cons.webp',
};

function getAreaBackground(title: string): string | null {
  const lower = title?.toLowerCase() ?? '';
  for (const [keyword, image] of Object.entries(areaBackgrounds)) {
    if (lower.includes(keyword)) return image;
  }
  return null;
}
---

<Layout>
	<section class="min-h-[calc(85vh-4rem)] bg-[#D9D8D3] flex items-center relative overflow-hidden">
		<!-- Background law image (hidden on mobile) -->
		<img
			src="/law.svg"
			alt=""
			aria-hidden="true"
			class="hidden md:block absolute left-0 top-0 h-full w-auto object-contain object-left opacity-30 pointer-events-none select-none"
		/>
		<div class="absolute bottom-0 left-0 right-0 h-4 bg-gradient-to-r from-amber-700 to-amber-500"></div>
		<div class="max-w-7xl mx-auto px-4 md:px-8 py-12 md:py-16 w-full">
			<div class="flex flex-col items-end text-right space-y-6 pr-4 md:pr-16 lg:pr-16">
				<h1 class="text-4xl md:text-5xl lg:text-6xl font-semibold leading-tight uppercase tracking-wider" style="font-family: 'Lora', serif; color: #1D2A3D;">
					Santos & Trevizan
				</h1>
				<p class="text-2xl" style="color: #1D2A3D;">
					Defendendo os Seus Direitos com Transparência e Eficiência
				</p>
				<div class="flex flex-wrap justify-end gap-4 pt-4">
					{/* <a href="/blog" class="px-6 py-3 bg-white text-slate-900 font-medium rounded-lg hover:bg-slate-100 transition-colors">
						Ver Artigos
					</a> */}
					<a
						href={whatsappUrl}
						target="_blank"
						rel="noopener noreferrer"
						class="inline-flex items-center gap-2.5 px-6 py-3 bg-green-500 hover:bg-green-600 text-white text-base font-semibold rounded-lg shadow-lg hover:shadow-green-500/40 transition-all duration-300 hover:scale-[1.03]"
					>
						<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="white" class="shrink-0">
							<path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
						</svg>
						Falar com um advogado
					</a>
				</div>
			</div>
		</div>
	</section>

	<!-- Áreas de Atuação Section -->
	<section id="areas" class="py-20 bg-[#1D2A3D]">
		<div class="max-w-7xl mx-auto px-8">
			<h2 class="text-4xl font-bold text-white mb-8">Áreas de Atuação</h2>
			{areas.length === 0 ? (
				<p class="text-slate-300">Nenhuma área de atuação cadastrada.</p>
			) : (
				<div class="grid grid-cols-1 md:grid-cols-3 gap-8">
					{areas.map((area: any) => {
						const bg = getAreaBackground(area.title);
						return (
							<div
								class={`p-6 rounded-xl relative overflow-hidden ${bg ? '' : 'bg-[#243350]'}`}
								style={bg
									? `background-image: url('${bg}'); background-size: cover; background-position: center; border: 1px solid transparent; background-clip: padding-box; outline: 1px solid transparent; box-shadow: 0 0 0 1px rgba(180,135,60,0.5);`
									: 'border: 1px solid transparent; background-image: linear-gradient(#243350, #243350), linear-gradient(135deg, #B8924A, #F0D080, #B8924A); background-origin: border-box; background-clip: padding-box, border-box;'
								}
							>
								{bg && <div class="absolute inset-0 bg-slate-900/65 rounded-xl"></div>}
								<div class="relative z-10">
									<h3 class="text-xl font-semibold text-white mb-3">{area.title}</h3>
									<p class={bg ? 'text-slate-200' : 'text-slate-300'}>{area.description}</p>
								</div>
							</div>
						);
					})}
				</div>
			)}
		</div>
	</section>

	<!-- Sobre Section -->
	<section id="sobre" class="py-20 bg-white">
		<div class="max-w-7xl mx-auto px-8">
			<h2 class="text-4xl font-bold text-slate-800 mb-8">Sobre</h2>
			<div class="max-w-3xl">
				<p class="text-lg text-slate-600 mb-4">
					Paloma Santos é advogada inscrita na OAB/SP, com experiência em diversas áreas do Direito. 
					Atua com foco em proporcionar um atendimento humanizado e soluções jurídicas eficientes.
				</p>
				<p class="text-lg text-slate-600">
					Formada em Direito, busca constantemente atualização profissional para oferecer 
					o melhor serviço aos seus clientes.
				</p>
			</div>
		</div>
	</section>

	<!-- Contato Section -->
	<section id="contato" class="py-20 bg-slate-900 text-white">
		<div class="max-w-7xl mx-auto px-8">
			<h2 class="text-4xl font-bold mb-8">Contato</h2>
			<div class="grid grid-cols-1 md:grid-cols-2 gap-12">
				<div>
					<p class="text-lg text-slate-300 mb-6">
						Entre em contato para agendar uma consulta ou tirar suas dúvidas.
					</p>
					<div class="space-y-4">
						<p class="flex items-center gap-3 text-slate-300">
							<span class="font-medium text-white">Email:</span> advogada.palomasantos@gmail.com
						</p>
						<p class="flex items-center gap-3 text-slate-300">
							<span class="font-medium text-white">Telefone:</span> (11) 95530-4453
						</p>
						<p class="flex items-center gap-3 text-slate-300">
							<span class="font-medium text-white">Endereço:</span> São Paulo, SP
						</p>
					</div>
				</div>
				<div class="bg-slate-800 p-8 rounded-xl">
					<h3 class="text-xl font-semibold mb-4">Horário de Atendimento</h3>
					<p class="text-slate-300">Segunda a Sexta: 9h às 18h</p>
					<p class="text-slate-300">Sábado: 9h às 12h (com agendamento)</p>
				</div>
			</div>
		</div>
	</section>
</Layout>
