---
import Layout from '../layouts/Layout.astro';

import { sanityClient } from 'sanity:client';

const whatsappPhone = "5511955304453";
const whatsappMessage = "Olá! Gostaria de mais informações sobre os serviços jurídicos.";
const whatsappUrl = `https://wa.me/${whatsappPhone}?text=${encodeURIComponent(whatsappMessage)}`;

function getAreaWhatsAppUrl(title: string) {
  const lower = title?.toLowerCase() ?? '';
  let msg = "Olá! Gostaria de mais informações sobre os serviços jurídicos.";
  
  if (lower.includes('trabalhist')) {
    msg = "Olá! Gostaria de tirar dúvidas sobre Direito Trabalhista (rescisão, horas extras, direitos trabalhistas). Poderia me ajudar?";
  } else if (lower.includes('civil')) {
    msg = "Olá! Gostaria de tirar dúvidas sobre Direito Civil (contratos, família, sucessões). Poderia me ajudar?";
  } else if (lower.includes('previdenci')) {
    msg = "Olá! Gostaria de tirar dúvidas sobre Direito Previdenciário (aposentadoria, benefícios, auxílios). Poderia me ajudar?";
  }
  
  return `https://wa.me/${whatsappPhone}?text=${encodeURIComponent(msg)}`;
}

const areas = await sanityClient.fetch(
  `*[_type == "areaDeAtuacao"] | order(order asc) {
    _id,
    title,
    description,
    icon,
    order
  }`
);

const areaData: Record<string, {
  icon: string;
  sections: { heading: string; text: string }[];
}> = {
  trabalhist: {
    icon: `<svg viewBox="0 0 48 48" width="44" height="44" fill="none" stroke="#B8924A" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
      <rect x="8" y="18" width="32" height="22" rx="3"/>
      <path d="M18 18v-4a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v4"/>
      <line x1="8" y1="28" x2="40" y2="28"/>
      <rect x="20" y="25" width="8" height="6" rx="1.5"/>
    </svg>`,
    sections: [
      { heading: 'Rescisão Contratual', text: 'Orientação informativa sobre modalidades de demissão (sem justa causa, por justa causa, rescisão indireta) e o correto cálculo das verbas rescisórias previstas na CLT.' },
      { heading: 'Jornada de Trabalho e Horas Extras', text: 'Esclarecimentos sobre os limites de jornada, banco de horas, adicional noturno, intervalos obrigatórios para repouso e alimentação, e o cálculo de horas extraordinárias.' },
      { heading: 'Direitos e Adicionais', text: 'Informações sobre o recolhimento do FGTS, férias, décimo terceiro salário, além de adicionais de insalubridade, periculosidade e respeito às convenções coletivas.' },
    ],
  },
  civil: {
    icon: `<svg viewBox="0 0 48 48" width="44" height="44" fill="none" stroke="#B8924A" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
      <line x1="24" y1="9" x2="24" y2="42"/>
      <line x1="15" y1="42" x2="33" y2="42"/>
      <line x1="7" y1="17" x2="41" y2="17"/>
      <line x1="11" y1="17" x2="11" y2="27"/>
      <path d="M6 27 Q11 32 16 27"/>
      <line x1="37" y1="17" x2="37" y2="27"/>
      <path d="M32 27 Q37 32 42 27"/>
    </svg>`,
    sections: [
      { heading: 'Análise e Elaboração de Contratos', text: 'Assessoria jurídica na elaboração, revisão e distrato de instrumentos particulares para conferir segurança e mitigar riscos em relações negociais.' },
      { heading: 'Direito do Consumidor', text: 'Defesa dos direitos do consumidor em contratos de consumo, cobranças indevidas, práticas abusivas e indenizações por falha na prestação de serviços ou produtos.' },
      { heading: 'Família e Planejamento Sucessório', text: 'Informações sobre divórcio consensual e litigioso, fixação de pensão alimentícia, termos de guarda de menores, partilha de bens e inventários judiciais ou extrajudiciais.' },
    ],
  },
  previdenci: {
    icon: `<svg viewBox="0 0 48 48" width="44" height="44" fill="none" stroke="#B8924A" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
      <path d="M24 6 L38 11 L38 24 Q38 35 24 42 Q10 35 10 24 L10 11 Z"/>
      <circle cx="24" cy="21" r="5"/>
      <path d="M15 36 Q15 30 24 30 Q33 30 33 36"/>
    </svg>`,
    sections: [
      { heading: 'Aposentadorias e Pensão', text: 'Estudo e planejamento de aposentadoria por idade, tempo de contribuição ou especial, além dos critérios para concessão de pensão por morte aos dependentes.' },
      { heading: 'Benefícios por Incapacidade', text: 'Informações objetivas sobre os requisitos exigidos pelo INSS para concessão e restabelecimento de auxílio-doença, aposentadoria por invalidez e auxílio-acidente.' },
      { heading: 'Benefício Assistencial', text: 'Informações sobre requisitos para concessão do Benefício de Prestação Continuada (BPC/LOAS) a idosos e pessoas com deficiência, além de auxílio na emissão do CadÚnico.' },
    ],
  },
};

function getAreaData(title: string) {
  const lower = title?.toLowerCase() ?? '';
  for (const [keyword, data] of Object.entries(areaData)) {
    if (lower.includes(keyword)) return data;
  }
  return null;
}
---

<Layout>
	<section id="hero" class="min-h-[calc(75vh-4rem)] bg-[#D9D8D3] flex items-center relative overflow-hidden">
		<!-- Hidden h1 for SEO / screen readers -->
		<h1 class="sr-only">Santos &amp; Trevizan — Advocacia e Assessoria</h1>
		<div class="absolute bottom-0 left-0 right-0 h-4 bg-gradient-to-r from-amber-700 to-amber-500"></div>
		<div class="max-w-7xl mx-auto px-4 md:px-6 py-12 md:py-16 w-full">
			<div class="flex flex-col md:flex-row items-center gap-4 md:gap-6">

				<!-- Left: Brand image (increased size on mobile) -->
				<div class="w-3/5 sm:w-1/2 md:w-2/5 md:flex-[2] flex items-center justify-center">
					<img
						src="/brand.webp"
						alt="Santos & Trevizan"
						class="w-full h-auto object-contain drop-shadow-sm"
					/>
				</div>

				<!-- Right: Tagline + CTA (3/5 width) -->
				<div class="w-full md:flex-[3] flex flex-col items-center md:items-end text-center md:text-right space-y-5">

					<!-- Supporting subtitle -->
					<p class="text-xl md:text-2xl lg:text-3xl leading-snug md:border-r-4 md:border-[#B8924A] md:pr-5" style="font-family: 'Lora', serif; color: #1D2A3D;">
						Atendimento humanizado e soluções jurídicas eficientes para você e sua família.
					</p>
					<div class="w-full pt-2 flex justify-center md:justify-end">
						<a
							href={whatsappUrl}
							target="_blank"
							rel="noopener noreferrer"
							class="w-full md:w-auto inline-flex items-center justify-center gap-3 px-8 py-4 bg-[#25D366] hover:bg-[#20ba56] text-white text-lg font-semibold rounded-lg shadow-lg transition-all duration-300 hover:scale-[1.02]"
						>
							<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="white" class="shrink-0">
								<path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
							</svg>
							Falar com um advogado
						</a>
					</div>
				</div>

			</div>
		</div>
	</section>

	<!-- Áreas de Atuação Section -->
	<section id="areas" class="py-20 bg-[#1D2A3D]">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 md:px-8">
			<h2 class="text-4xl font-bold text-white mb-10">Áreas de Atuação</h2>
			{areas.length === 0 ? (
				<p class="text-slate-300">Nenhuma área de atuação cadastrada.</p>
			) : (
				<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
					{areas.map((area: any, idx: number) => {
						const data = getAreaData(area.title);
						return (
							<a
								href={getAreaWhatsAppUrl(area.title)}
								target="_blank"
								rel="noopener noreferrer"
								class={`group relative bg-[#243350] hover:bg-[#293a5a] border border-[#B8924A]/25 hover:border-[#F0D080]/50 rounded-xl p-5 sm:p-7 flex flex-col min-h-0 md:min-h-[460px] cursor-pointer transition-all duration-300 hover:scale-[1.02] active:scale-[0.98] hover:shadow-xl no-underline focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#B8924A] ${idx === 2 ? 'md:col-span-2 md:max-w-md md:mx-auto lg:col-span-1 lg:max-w-none lg:mx-0' : ''}`}
							>
								<!-- Golden L-bracket corner accent (overflows top-left) -->
								<div class="absolute" style="top: -12px; left: -12px; width: 36px; height: 36px; pointer-events: none;">
									<!-- Vertical arm -->
									<div style="position:absolute; top:0; left:0; width:2px; height:36px; background: linear-gradient(to bottom, #F0D080, #B8924A);"></div>
									<!-- Horizontal arm -->
									<div style="position:absolute; top:0; left:0; width:36px; height:2px; background: linear-gradient(to right, #F0D080, #B8924A);"></div>
								</div>

								<!-- Header: icon + title -->
								<div class="flex items-center gap-4 mb-6">
									{data && <div set:html={data.icon} class="shrink-0" />}
									<h3 class="text-xl font-semibold text-white leading-tight">{area.title}</h3>
								</div>

								<!-- 3 content sections -->
								<div class="flex flex-col gap-0 flex-1">
									{data?.sections.map((section, i) => (
										<div class={i > 0 ? 'border-t border-slate-700/60 pt-4 mt-4' : ''}>
											<h4 class="text-lg font-semibold mb-1" style="color: #D4A857;">{section.heading}</h4>
											<p class="text-slate-300 text-base leading-relaxed">{section.text}</p>
										</div>
									))}
									{!data && <p class="text-slate-300">{area.description}</p>}
								</div>

								<!-- Redundant CTA Button -->
								<div class="mt-8 pt-4 border-t border-slate-700/50 flex items-center justify-between text-sm font-semibold tracking-wider uppercase transition-colors duration-300 group-hover:text-[#F0D080]" style="color: #B8924A;">
									<span>Fale com um especialista</span>
									<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="transform transition-transform duration-300 group-hover:translate-x-1">
										<line x1="5" y1="12" x2="19" y2="12"></line>
										<polyline points="12 5 19 12 12 19"></polyline>
									</svg>
								</div>
							</a>
						);
					})}
				</div>
			)}
		</div>
	</section>

	<!-- Sobre Section -->
	<section id="sobre" class="py-24 bg-slate-50 relative overflow-hidden">
		<!-- Decorative background shape -->
		<div class="absolute top-0 right-0 w-96 h-96 bg-[#B8924A]/5 rounded-full blur-3xl pointer-events-none"></div>
		
		<div class="max-w-7xl mx-auto px-4 sm:px-6 md:px-8 relative">
			<div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
				
				<!-- Left column: Title & Biography (7/12 cols) -->
				<div class="lg:col-span-7 space-y-6">
					<div class="inline-block px-3 py-1 bg-[#1D2A3D]/5 text-[#1D2A3D] text-xs font-semibold uppercase tracking-wider rounded">
						Perfil Profissional
					</div>
					<h2 class="text-4xl md:text-5xl font-bold leading-tight" style="font-family: 'Lora', serif; color: #1D2A3D;">
						Sobre o Escritório
					</h2>
					<div class="space-y-4 text-base md:text-lg leading-relaxed text-slate-600">
						<p>
							Santos & Trevizan é um escritório de advocacia estruturado para prestar serviços jurídicos com ética, transparência e rigor técnico. A atuação da equipe é pautada pelo atendimento personalizado e humanizado, buscando compreender a singularidade de cada caso para apresentar caminhos eficientes na resolução de conflitos.
						</p>
						<p>
							Com sólida experiência jurídica e constante aprimoramento técnico e prático, o escritório pauta seu trabalho na defesa dos direitos individuais e na construção de soluções jurídicas sólidas, tanto na esfera administrativa quanto judicial.
						</p>
						<p>
							Com <strong>alcance nacional</strong>, o escritório oferece atendimento 100% digital — por videochamada, WhatsApp e e-mail — permitindo que clientes de qualquer região do Brasil tenham acesso a uma assessoria jurídica de qualidade, sem a necessidade de deslocamento. Essa estrutura garante agilidade, proximidade e conveniência em todas as etapas do processo.
						</p>
					</div>
				</div>

				<!-- Right column: Pillars / Core Values (5/12 cols) -->
				<div class="lg:col-span-5 bg-white p-5 md:p-8 rounded-2xl shadow-xl border border-slate-100 space-y-6">
					<h3 class="text-xl font-bold" style="color: #1D2A3D;">Diretrizes de Atuação</h3>
					
					<div class="space-y-4">
						<div class="flex items-start gap-4">
							<div class="p-3 bg-[#B8924A]/10 rounded-xl text-[#B8924A] shrink-0">
								<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
									<circle cx="12" cy="12" r="10"/>
									<path d="m9 12 2 2 4-4"/>
								</svg>
							</div>
							<div>
								<h4 class="font-bold text-base text-slate-800">Compromisso Ético</h4>
								<p class="text-sm text-slate-600">Atuação pautada pela transparência absoluta e sigilo profissional em todas as etapas da assessoria.</p>
							</div>
						</div>
						
						<div class="flex items-start gap-4">
							<div class="p-3 bg-[#B8924A]/10 rounded-xl text-[#B8924A] shrink-0">
								<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
									<path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/>
									<circle cx="9" cy="7" r="4"/>
									<path d="M22 21v-2a4 4 0 0 0-3-3.87"/>
									<path d="M16 3.13a4 4 0 0 1 0 7.75"/>
								</svg>
							</div>
							<div>
								<h4 class="font-bold text-base text-slate-800">Atendimento Humanizado</h4>
								<p class="text-sm text-slate-600">Escuta ativa para entender as dores do cliente, explicando os termos jurídicos de forma simples e acessível.</p>
							</div>
						</div>
						
						<div class="flex items-start gap-4">
							<div class="p-3 bg-[#B8924A]/10 rounded-xl text-[#B8924A] shrink-0">
								<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
									<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
								</svg>
							</div>
							<div>
								<h4 class="font-bold text-base text-slate-800">Rigor Técnico</h4>
								<p class="text-sm text-slate-600">Estudo aprofundado da jurisprudência e doutrina para construir teses defensivas sólidas.</p>
							</div>
						</div>
					</div>
				</div>

			</div>
		</div>
	</section>

	<!-- Contato Section -->
	<footer id="contato" class="py-20 bg-slate-900 text-white" role="contentinfo">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 md:px-8">
			<h2 class="text-4xl font-bold mb-8">Contato</h2>
			<div class="grid grid-cols-1 md:grid-cols-2 gap-12">
				<div>
					<p class="text-lg text-slate-300 mb-6">
						Entre em contato para agendar uma consulta ou tirar suas dúvidas.
					</p>
					<div class="space-y-4">
						<p class="flex items-center gap-3 text-slate-300">
							<span class="font-medium text-white">Email:</span>
							<a href="#" id="email-contact" class="hover:text-amber-500 transition-colors no-underline focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#B8924A] rounded"></a>
						</p>
						<p class="flex items-center gap-3 text-slate-300">
							<span class="font-medium text-white">Telefone:</span>
							<a href="#" id="phone-contact" class="hover:text-amber-500 transition-colors no-underline focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#B8924A] rounded"></a>
						</p>
						<p class="flex items-center gap-3 text-slate-300">
							<span class="font-medium text-white">Endereço:</span> São Paulo, SP
						</p>
					</div>

					<script is:inline>
						// Client-side obfuscation to prevent simple spam/scraper crawlers from finding email & phone details.
						const user = "advogada.palomasantos";
						const domain = "gmail.com";
						const email = `${user}@${domain}`;
						const emailEl = document.getElementById("email-contact");
						if (emailEl) {
							emailEl.href = `mailto:${email}`;
							emailEl.textContent = email;
						}

						const ddd = "11";
						const p1 = "95530";
						const p2 = "4453";
						const phoneEl = document.getElementById("phone-contact");
						if (phoneEl) {
							phoneEl.href = `tel:+55${ddd}${p1}${p2}`;
							phoneEl.textContent = `(${ddd}) ${p1}-${p2}`;
						}
					</script>
				</div>
				<div class="bg-slate-800 p-8 rounded-xl">
					<h3 class="text-xl font-semibold mb-4">Horário de Atendimento</h3>
					<p class="text-slate-300">Segunda a Sexta: 9h às 18h</p>
					<p class="text-slate-300">Sábado: 9h às 12h (com agendamento)</p>
				</div>
			</div>
		</div>
	</footer>
</Layout>
